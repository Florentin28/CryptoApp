@page "/login"
@using CryptoApp.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Connexion</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-body">
                <h3 class="text-center mb-4">Connexion / Inscription</h3>
                <p class="text-muted text-center">Entrez un pseudo pour créer un compte ou vous y reconnecter.</p>

                <div class="mb-3">
                    <label class="form-label">Nom d'utilisateur (Pseudo)</label>
                    <input @bind="username" class="form-control" placeholder="Ex: Jean Michel" />
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Mot de passe</label>
                    <input type="password" @bind="password" class="form-control" placeholder="*******" />
                </div>
                
                <button class="btn btn-primary w-100" @onclick="Connecter">Se connecter</button>
            </div>
        </div>
    </div>
</div>

@code {
    private string username = "";
    private string password = ""; // Ignoré dans la logique, juste pour le réalisme visuel !

    private async Task Connecter()
    {
        if (!string.IsNullOrWhiteSpace(username))
        {
            var provider = (FakeAuthStateProvider)AuthStateProvider;
            await provider.LoginAsync(username);
            NavigationManager.NavigateTo("/"); // Redirige vers l'accueil
        }
    }
}