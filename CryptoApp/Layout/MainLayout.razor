@inherits LayoutComponentBase
@using CryptoApp.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="me-3">Bonjour, <strong>@context.User.Identity?.Name</strong> !</span>
                    <button class="btn btn-outline-danger btn-sm" @onclick="Logout">Se déconnecter</button>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="btn btn-primary btn-sm">Se connecter</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private async Task Logout()
    {
        var provider = (FakeAuthStateProvider)AuthStateProvider;
        await provider.LogoutAsync();
        NavigationManager.NavigateTo("/login");
    }
}